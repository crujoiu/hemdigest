---
import BaseLayout from "../layouts/BaseLayout.astro";
import { getDigestData } from "../lib/digest";

const pageTitle = "Hematology Digest | Latest Research & News";
const initialDigest = await getDigestData();
---

<BaseLayout title={pageTitle} description="Hematology research, journals, and specialty news in one digest.">
  <a class="skip-link" href="#main-content">Skip to content</a>

  <div id="loading-overlay" class="loading-overlay" aria-live="polite" aria-busy="true" role="status">
    <div class="loading-overlay__content">
      <div class="loading-spinner" aria-hidden="true"></div>
      <p class="loading-overlay__label">Loading hematology digest</p>
    </div>
  </div>

  <main class="page-shell" id="main-content">
    <section class="hero">
      <div class="hero__content">
        <button id="theme-toggle" class="theme-toggle" type="button" aria-label="Switch color theme" aria-pressed="false">
          <span class="theme-toggle__track">
            <span class="theme-toggle__icon theme-toggle__icon--sun" aria-hidden="true">Sun</span>
            <span class="theme-toggle__thumb"></span>
            <span class="theme-toggle__icon theme-toggle__icon--moon" aria-hidden="true">Moon</span>
          </span>
        </button>
        <p class="hero__eyebrow">Clinical Briefing</p>
        <h1 id="digest-title">Hematology Digest</h1>
        <p class="hero__tagline" id="digest-tagline">
          Loading hematology research, publications, and news from the backend.
        </p>
        <p class="hero__lede">
          A curated hematology briefing covering recent PubMed research, journal articles, and specialty news.
        </p>
        <div class="hero__stats">
          <div class="hero__stat">
            <span class="hero__stat-label">Updated</span>
            <strong id="digest-updated">Loading</strong>
          </div>
          <div class="hero__stat">
            <span class="hero__stat-label">Entries</span>
            <strong id="digest-total">0</strong>
          </div>
          <div class="hero__stat">
            <span class="hero__stat-label">Coverage</span>
            <strong id="digest-coverage">0 streams</strong>
          </div>
          <div class="hero__stat">
            <span class="hero__stat-label">Duplicates Removed</span>
            <strong id="digest-deduped">0</strong>
          </div>
        </div>
      </div>
    </section>

    <section class="overview-panel" id="overview-panel" aria-label="Digest overview">
      <div class="overview-panel__summary">
        <p class="digest-section__eyebrow">Overview</p>
        <h2>Priority developments</h2>
        <p id="overview-health">Reviewing source health and top activity.</p>
        <div class="overview-panel__presets" id="overview-presets">
          <span class="overview-preset">Loading presets</span>
        </div>
      </div>
      <div class="overview-panel__content">
        <div class="overview-panel__metrics" id="overview-metrics">
          <article class="overview-card">
            <p class="overview-card__label">Top developments</p>
            <strong>Loading</strong>
          </article>
        </div>
        <div class="overview-panel__spotlight" id="overview-spotlight">
          <article class="spotlight-card">
            <p class="spotlight-card__eyebrow">Loading</p>
            <h3>Preparing briefing highlights</h3>
          </article>
        </div>
      </div>
    </section>

    <section class="control-bar" aria-label="Digest controls">
      <div class="control-bar__search">
        <div class="control-bar__field">
          <label class="control-bar__label" for="digest-search">Search</label>
          <input id="digest-search" class="control-bar__input" type="search" placeholder="Search titles, summaries, topics" />
        </div>
      </div>
      <div class="control-bar__filters">
        <div class="control-bar__field">
          <label class="control-bar__label" for="topic-filter">Topic</label>
          <select id="topic-filter" class="control-bar__select">
            <option value="all">All topics</option>
          </select>
        </div>
        <div class="control-bar__field">
          <label class="control-bar__label" for="content-filter">Content</label>
          <select id="content-filter" class="control-bar__select">
            <option value="all">All content</option>
          </select>
        </div>
        <div class="control-bar__field">
          <label class="control-bar__label" for="audience-filter">Audience</label>
          <select id="audience-filter" class="control-bar__select">
            <option value="all">All audiences</option>
          </select>
        </div>
      </div>
      <div class="control-bar__actions">
        <div class="control-bar__field">
          <label class="control-bar__label" for="preset-filter">Preset</label>
          <select id="preset-filter" class="control-bar__select">
            <option value="">Choose preset</option>
          </select>
        </div>
        <div class="control-bar__button-row">
          <button id="bookmarks-toggle" class="control-bar__button" type="button" aria-pressed="false">Bookmarks only</button>
          <button id="new-toggle" class="control-bar__button" type="button" aria-pressed="false">New since last visit</button>
          <button id="clear-filters" class="control-bar__button control-bar__button--secondary" type="button">Clear filters</button>
        </div>
      </div>
    </section>

    <nav class="section-nav" aria-label="Digest sections" id="section-nav">
      <span class="section-nav__link">Loading sections…</span>
    </nav>

    <div id="digest-error" class="empty-state is-hidden" role="alert"></div>
    <div id="digest-sections" aria-live="polite"></div>
  </main>

  <button id="back-to-top" class="back-to-top is-hidden" type="button" aria-label="Back to top">
    Top
  </button>

  <footer class="site-footer">
    <p>Built with Astro and backed by a small TypeScript API.</p>
    <p>For educational and informational purposes only. Always verify against primary sources.</p>
  </footer>

  <noscript>
    <div class="noscript-banner">
      JavaScript is required to load the live digest content from the backend API.
    </div>
  </noscript>

  <script id="digest-initial-data" type="application/json" set:html={JSON.stringify(initialDigest)}></script>

  <script>
    import "../lib/digest-page";
  </script>
</BaseLayout>
